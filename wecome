<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NFC Asset Hub - Mobile</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- React 및 Babel CDN (브라우저에서 JSX 실행용) -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fastly.jsdelivr.net/gh/projectnoonnu/noonfonts_2001@1.1/GmarketSansBold.woff');
        body { font-family: 'GmarketSansBold', sans-serif; }
        .action-card:active { transform: scale(0.97); }
    </style>
</head>
<body class="bg-slate-50">
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect } = React;

        // Firebase Mock/Setup - 실제 배포시에는 실제 설정값을 넣어야 합니다.
        const assetInfo = {
            id: "IT-2024-0825",
            name: "A3 컬러 복합기",
            location: "본관 3층 대회의실",
            status: "정상"
        };

        const App = () => {
            const [isReporting, setIsReporting] = useState(false);
            const [reportSuccess, setReportSuccess] = useState(false);

            const handleReportIssue = () => {
                setIsReporting(true);
                // 여기에 실제 Firebase 연동 로직이 들어갑니다.
                // 데모를 위해 1.5초 후 성공 처리
                setTimeout(() => {
                    setIsReporting(false);
                    setReportSuccess(true);
                    setTimeout(() => setReportSuccess(false), 3000);
                }, 1500);
            };

            const ActionButton = ({ title, desc, iconName, color, onClick, type, link, status }) => {
                const Icon = () => {
                    useEffect(() => { lucide.createIcons(); }, []);
                    return <i data-lucide={iconName} className="w-6 h-6"></i>;
                };

                return (
                    <button 
                        onClick={type === 'action' ? onClick : () => window.location.href = link}
                        className="flex items-center w-full p-5 bg-white border border-slate-100 rounded-3xl shadow-sm hover:shadow-md transition-all action-card mb-4"
                    >
                        <div className={`${color} text-white p-4 rounded-2xl shadow-lg mr-5`}>
                            <Icon />
                        </div>
                        <div className="flex-1 text-left">
                            <h3 className="font-bold text-zinc-800 text-lg">{title}</h3>
                            <p className="text-xs text-zinc-400 mt-1">{desc}</p>
                        </div>
                        <i data-lucide="chevron-right" className="text-zinc-300 w-6 h-6"></i>
                    </button>
                );
            };

            return (
                <div className="flex justify-center min-h-screen">
                    <div className="w-full max-w-md bg-white shadow-2xl flex flex-col min-h-screen">
                        {/* 헤더 */}
                        <header className="bg-zinc-900 text-white p-8 pt-12 rounded-b-[2.5rem] shadow-lg">
                            <div className="flex justify-between items-start mb-8">
                                <div>
                                    <span className="bg-blue-500 text-white text-[10px] px-2.5 py-1 rounded-full font-bold uppercase tracking-widest">Asset Hub</span>
                                    <h1 className="text-2xl font-black mt-3 leading-tight">{assetInfo.name}</h1>
                                    <p className="text-zinc-400 text-sm mt-1">{assetInfo.location}</p>
                                </div>
                                <div className="bg-green-500/20 p-3 rounded-2xl">
                                    <i data-lucide="shield-check" className="text-green-400 w-7 h-7"></i>
                                </div>
                            </div>
                            <div className="flex gap-6 border-t border-zinc-800 pt-6 text-xs">
                                <div>
                                    <p className="text-zinc-500 mb-1 font-bold">관리번호</p>
                                    <p className="text-sm font-medium">{assetInfo.id}</p>
                                </div>
                                <div className="border-l border-zinc-800 pl-6">
                                    <p className="text-zinc-500 mb-1 font-bold">운영 상태</p>
                                    <p className="text-sm font-medium text-green-400">{assetInfo.status}</p>
                                </div>
                            </div>
                        </header>

                        {/* 버튼 리스트 */}
                        <main className="flex-1 px-6 py-10">
                            <h2 className="text-[11px] font-black text-zinc-400 uppercase tracking-[0.2em] ml-1 mb-4">Service Menu</h2>
                            
                            <ActionButton 
                                title="사용 매뉴얼" 
                                desc="기기 기본 사용법 및 가이드 확인" 
                                iconName="book-open" 
                                color="bg-blue-600" 
                                type="link"
                                link="#"
                            />

                            <ActionButton 
                                title={reportSuccess ? "접수 완료!" : (isReporting ? "접수 중..." : "고장/수리 접수")}
                                desc={reportSuccess ? "담당자가 곧 확인하겠습니다." : "장애 발생 시 관리자에게 즉시 신고"} 
                                iconName={reportSuccess ? "check-circle-2" : "wrench"} 
                                color={reportSuccess ? "bg-green-600" : "bg-red-500"} 
                                type="action"
                                onClick={handleReportIssue}
                            />

                            <ActionButton 
                                title="관리자 통화" 
                                desc="긴급 상황 발생 시 유선 문의" 
                                iconName="phone" 
                                color="bg-zinc-800" 
                                type="link"
                                link="tel:010-1234-5678"
                            />

                            <div className="mt-10 p-5 bg-blue-50/50 rounded-3xl border border-blue-100/50 flex gap-4">
                                <i data-lucide="alert-circle" className="text-blue-500 shrink-0 w-5 h-5"></i>
                                <div>
                                    <p className="text-xs font-bold text-blue-900 mb-1">안내사항</p>
                                    <p className="text-[11px] text-blue-700/70 leading-relaxed">
                                        NFC 터치를 통해 기기의 현재 상태를 확인하고 서비스를 요청할 수 있습니다.
                                    </p>
                                </div>
                            </div>
                        </main>

                        <footer className="p-8 text-center text-zinc-300 text-[10px] font-bold tracking-[0.1em] mt-auto uppercase">
                            Asset Management System
                        </footer>
                    </div>
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
        
        // 아이콘 초기화 대기
        setTimeout(() => lucide.createIcons(), 100);
    </script>
</body>
</html>
